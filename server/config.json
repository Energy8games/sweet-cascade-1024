{
  "id": "sweet-cascade-1024",
  "type": "SLOT",
  "version": "1.0.0",
  "rtp": "96.5",
  "engine_mode": "lua",
  "script_path": "games/sweet-cascade/script.lua",
  "viewport": {
    "width": 7,
    "height": 7
  },
  "stages": [
    "base_game",
    "free_spins"
  ],
  "bet_levels": [
